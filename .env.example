# Pooled connection string from Neon console (omit channel_binding=require)
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# One-time seed owner bootstrap (preserves existing finance data on SEED_USER_ID)
BOOTSTRAP_EMAIL=
BOOTSTRAP_PASSWORD=

# Optional: rate limiting (recommended in production)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Skip production bootstrap check locally
# SKIP_AUTH_BOOTSTRAP_CHECK=1
