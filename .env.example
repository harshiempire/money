# Copy to `.env.local` and fill in real values:
#   cp .env.example .env.local
#
# Next.js loads `.env.local` automatically for `pnpm dev` / `pnpm build`.
# Drizzle CLI (`pnpm db:*`) also reads `.env.local` via drizzle.config.ts.

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# Pooled connection string from Neon console (omit channel_binding=require)
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Auth.js v5 / next-auth
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# One-time seed owner bootstrap (preserves existing finance data on SEED_USER_ID)
BOOTSTRAP_EMAIL=
BOOTSTRAP_PASSWORD=

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------

# Rate limiting (recommended in production)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Skip production bootstrap check locally
# SKIP_AUTH_BOOTSTRAP_CHECK=1
