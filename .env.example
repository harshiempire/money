# Copy to `.env.local` and fill in real values:
#   cp .env.example .env.local
#
# Next.js loads `.env.local` automatically for `pnpm dev` / `pnpm build`.
# Drizzle CLI (`pnpm db:*`) also reads `.env.local` via drizzle.config.ts.

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# Neon (or any Postgres) connection string.
# Neon dashboard → your project → Connect → Connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# -----------------------------------------------------------------------------
# Optional (not used yet — Auth.js is in package.json but not wired up)
# -----------------------------------------------------------------------------
# When you add sign-in, uncomment and set these (Auth.js v5 / next-auth v5):
#
# AUTH_SECRET=generate-with-openssl-rand-base64-32
# AUTH_URL=http://localhost:3000
#
# OAuth example (Google):
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
